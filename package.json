{
  "name": "@bhuvanprakash/jsonsettle",
  "version": "0.1.0",
  "description": "Schema-aware streaming JSON parser for LLMs. Know exactly which fields are certain vs still streaming — in real time.",
  "keywords": [
    "llm",
    "streaming",
    "json",
    "parser",
    "openai",
    "anthropic",
    "structured-output",
    "zod"
  ],
  "author": "Bhuvan Prakash",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/bhuvan/jsonsettle"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/adapters/react.d.ts",
      "import": "./dist/adapters/react.js",
      "require": "./dist/adapters/react.cjs"
    },
    "./zod": {
      "types": "./dist/schema/zod.d.ts",
      "import": "./dist/schema/zod.js",
      "require": "./dist/schema/zod.cjs"
    },
    "./vue": {
      "types": "./dist/adapters/vue.d.ts",
      "import": "./dist/adapters/vue.js",
      "require": "./dist/adapters/vue.cjs"
    },
    "./vanilla": {
      "types": "./dist/adapters/vanilla.d.ts",
      "import": "./dist/adapters/vanilla.js",
      "require": "./dist/adapters/vanilla.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "react": [
        "dist/adapters/react.d.ts"
      ],
      "vue": [
        "dist/adapters/vue.d.ts"
      ],
      "vanilla": [
        "dist/adapters/vanilla.d.ts"
      ],
      "zod": [
        "dist/schema/zod.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "bench": "npx tsx benchmarks/run.ts && npx tsx benchmarks/graph.ts",
    "bench:compare": "npx tsx benchmarks/compare.ts && npx tsx benchmarks/graph.ts",
    "bench:memory": "node --expose-gc --import tsx benchmarks/memory.ts && npx tsx benchmarks/graph.ts",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration/",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "demo": "npx serve demo",
    "prepublishOnly": "npm run build && npm run test"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@streamparser/json": "^0.0.22",
    "@types/react": "^18.0.0",
    "openai": "^6.34.0",
    "partial-json": "^0.1.7",
    "tinybench": "^4.1.0",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0",
    "vue": "^3.4.0",
    "zod": "^3.22.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "vue": ">=3",
    "zod": ">=3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "zod": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "dependencies": {
    "twine": "^2.0.0"
  }
}
