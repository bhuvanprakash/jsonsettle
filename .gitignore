# ── Dependencies ──────────────────────────────────────────────
node_modules/

# ── Build output (regenerated by npm run build) ───────────────
dist/

# ── Environment / secrets ─────────────────────────────────────
.env
.env.*
!.env.example

# ── TypeScript ────────────────────────────────────────────────
*.tsbuildinfo

# ── Test & coverage ───────────────────────────────────────────
coverage/

# ── Benchmark results (raw JSON runs) ─────────────────────────
benchmarks/results/*.json
benchmarks/results/graphs.md

# ── Python ────────────────────────────────────────────────────
python/.venv/
python/dist/
python/**/__pycache__/
python/src/*.egg-info/
**/__pycache__/
*.pyc
*.pyo

# ── macOS ─────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── Editor ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS ────────────────────────────────────────────────────────
Thumbs.db